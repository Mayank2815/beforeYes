rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // PDFs are only accessible via signed URLs generated by the Admin SDK
    // No public access to any paths
    match /pdfs/{sessionId}/{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
