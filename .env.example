# ============================================================
# BeforeYes — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# Firebase Client SDK (safe to expose in browser bundle)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ------------------------------------------------------------
# Firebase Admin SDK (SERVER-SIDE ONLY — never expose to client)
# ------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key with \n escaping for newlines:
# e.g. "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ------------------------------------------------------------
# Razorpay
# ------------------------------------------------------------
# Key ID is safe to expose to the client for checkout.js
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-side copy of Key ID (used in API routes)
RAZORPAY_KEY_ID=
# SECRET — NEVER expose client-side
RAZORPAY_SECRET=

# ------------------------------------------------------------
# AI Provider (Google Gemini — free tier)
# Get your key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# Anthropic AI (optional — legacy provider)
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_BASE_URL=https://beforeyes.in
# Price in paise (₹499 = 49900)
NEXT_PUBLIC_REPORT_PRICE_PAISE=49900
